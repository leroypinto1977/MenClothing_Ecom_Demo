# Neon Postgres (project: meridian-store / long-cake-13207237)
DATABASE_URL=

# Better Auth (Phase 2)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Razorpay (Phase 4)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Resend transactional email (see docs/email-plan.md).
# Without RESEND_API_KEY, emails are logged instead of sent (demo-safe).
RESEND_API_KEY=
# Verified sender; defaults to Resend's sandbox "onboarding@resend.dev".
RESEND_FROM="MERIDIAN <orders@send.meridian.in>"
# Monitored human inbox shown as Reply-To.
RESEND_REPLY_TO="support@meridian.in"
# Optional: receives the internal new-order alert. Leave blank to disable.
ADMIN_ORDER_EMAIL=
